{"type":"CPT","code":"00162","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing radical surgery on the nose and accessory sinuses.\"","version":"CPT 2026"},{"type":"CPT","code":"00164","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing soft tissue biopsy of the nose and accessory sinuses.\"","version":"CPT 2026"},{"type":"CPT","code":"00170","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intraoral procedure including biopsy.\"","version":"CPT 2026"},{"type":"CPT","code":"00172","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intraoral procedure including biopsy and repair of a cleft palate.\"","version":"CPT 2026"},{"type":"CPT","code":"00174","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intraoral procedure including biopsy and excision of a retropharyngeal tumor.\"","version":"CPT 2026"},{"type":"CPT","code":"00176","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intraoral procedure including biopsy radical surgery.\"","version":"CPT 2026"},{"type":"CPT","code":"00190","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the facial bones or the skull.\"","version":"CPT 2026"},{"type":"CPT","code":"00192","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing radical surgery procedures on the facial bones or skull. This may include prognathism which is a protrusion of the lower jaw.\"","version":"CPT 2026"},{"type":"CPT","code":"00210","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial procedures that are not specifically described by another anesthesia code.\"","version":"CPT 2026"},{"type":"CPT","code":"00211","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial procedures that involve removing a small portion of skull bone to take out a hematoma or blood clot from within the brain or tissues surrounding it.\"","version":"CPT 2026"},{"type":"CPT","code":"00212","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial procedures involving subdural taps. In this procedure another provider removes a little fluid from the subdural space the fluid filled space in between the outer and middle membrane layers covering the brain. The surgical provider performs the procedure to decrease the excess intracranial fluid pressure being exerted on the brain tissues.\"","version":"CPT 2026"},{"type":"CPT","code":"00214","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial procedures involving burr holes and possibly ventriculography.\"","version":"CPT 2026"},{"type":"CPT","code":"00215","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing extradural intracranial procedures involving cranioplasty or raising a depressed skull fracture.\"","version":"CPT 2026"},{"type":"CPT","code":"67599","description":"\"Other Procedures on the Orbit.\"","category":"Surgery","procedureDetails":"\"Use  to report procedures in the orbit of the eye that do not have a specific code.\"","version":"CPT 2026"},{"type":"CPT","code":"00216","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial vascular procedures.\"","version":"CPT 2026"},{"type":"CPT","code":"00218","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intracranial procedure while in a sitting position.\"","version":"CPT 2026"},{"type":"CPT","code":"00220","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing intracranial procedures for cerebrospinal fluid shunting.\"","version":"CPT 2026"},{"type":"CPT","code":"00222","description":"\"Anesthesia for Procedures on the Head.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing an intracranial procedure including electrocoagulation of an intracranial nerve which means to stop bleeding using electrocautery or an electrical current.\"","version":"CPT 2026"},{"type":"CPT","code":"00300","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the integumentary system muscles and nerves of head neck and posterior trunk.\"","version":"CPT 2026"},{"type":"CPT","code":"00320","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the esophagus thyroid larynx trachea and lymphatic system of the neck when the patient is one year or older.\"","version":"CPT 2026"},{"type":"CPT","code":"00322","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the esophagus thyroid larynx trachea and lymphatic system of the neck including a needle biopsy of the thyroid.\"","version":"CPT 2026"},{"type":"CPT","code":"00326","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the larynx and trachea in children younger than one year of age.\"","version":"CPT 2026"},{"type":"CPT","code":"00350","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the major vessels of the neck not otherwise specified.\"","version":"CPT 2026"},{"type":"CPT","code":"00352","description":"\"Anesthesia for Procedures on the Neck.Anesthesia. General Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the major vessels of neck including simple ligation.\"","version":"CPT 2026"},{"type":"CPT","code":"00400","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing any procedure on the integumentary system on the extremities anterior trunk and perineum not otherwise specified.\"","version":"CPT 2026"},{"type":"CPT","code":"00402","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the integumentary system on the extremities anterior trunk and perineum including reconstructive procedures on the breast.\"","version":"CPT 2026"},{"type":"CPT","code":"00404","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the integumentary system on the extremities anterior trunk and perineum including a radical or modified radical procedure on the breast.\"","version":"CPT 2026"},{"type":"CPT","code":"00406","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the integumentary system of the extremities anterior trunk and perineum including a radical or modified radical procedure on the breast with internal mammary node dissection.\"","version":"CPT 2026"},{"type":"CPT","code":"00410","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the skin of the upper and lower limbs the front aspect of the chest and abdomen or the perineum. For this code the patient’s treatment includes electrical conversion for treating the irregularity of heartbeats.\"","version":"CPT 2026"},{"type":"CPT","code":"00450","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the clavicle and scapula which is not specified by another code. The clavicle and scapula are bones in the upper torso.\"","version":"CPT 2026"},{"type":"CPT","code":"00454","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a biopsy procedure on the clavicle which is the collarbone.\"","version":"CPT 2026"},{"type":"CPT","code":"00470","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing partial rib removal in a procedure not otherwise specified by another code.\"","version":"CPT 2026"},{"type":"CPT","code":"00472","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing partial rib resection including thoracoplasty in which another provider partially removes one or more ribs. The surgery may involve a reparative procedure on the thorax.\"","version":"CPT 2026"},{"type":"CPT","code":"00474","description":"\"Anesthesia for Procedures on the Thorax (Chest Wall and Shoulder Girdle).Anesthesia. Regional Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a partial rib resection in which the surgical provider removes a portion of the ribs. The radical procedure involves other extensive measures for treating conditions such as pectus excavatum which is a hollow depression in the center of the lower chest.\"","version":"CPT 2026"},{"type":"CPT","code":"00500","description":"\"Anesthesia for Intrathoracic Procedures.Anesthesia. Local Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing a procedure on the esophagus which is the food pipe.\"","version":"CPT 2026"},{"type":"CPT","code":"00520","description":"\"Anesthesia for Intrathoracic Procedures.Anesthesia. Local Anesthesia\"","category":"Anesthesiology","procedureDetails":"\"The provider performs anesthesia services for a patient undergoing closed chest procedures including bronchoscopy which means viewing the windpipe for investigation. This code includes procedures that are not specifically described by another anesthesia code.\"","version":"CPT 2026"},{"type":"HCPCS","code":"A0021","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0080","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0090","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0100","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0110","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0120","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0130","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0140","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0160","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0170","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0180","description":"Ambulance and Other Transport Services and Supplies.Ambulance services","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A0190","description":"Ambulance and Other Transport Services and Supplies.Ambulance serv