1:00:50 PM [express] GET /api/codes/search 200 in 802ms :: [{"type":"CPT","code":"21453","description":"\"Fracture and/or Dislocation Procedures on the Head.Musculoskeletal. Orthopedic Procedures\"","category":"Surgery","procedureDetails":"\"The provider treats a fracture of the mandible or lower jaw bone to repair damage caused by blunt force trauma to the face. He uses a device that connects to the teeth to secure the fracture in place while it heals.\"","version":"CPT 2026"},{"type":"CPT","code":"24530","description":"\"Fracture and/or Dislocation Procedures on the Humerus (Upper Arm) and Elbow.Musculoskeletal. Orthopedic Procedures\"","category":"Surgery","procedureDetails":"\"The provider treats a fracture of the humerus the upper arm bone through or above a condyle a rounded projection at the end of the bone but without extending between the condyles. He does not make an incision or manipulate the fracture.\"","version":"CPT 2026"},{"type":"CPT","code":"24535","description":"\"Fracture and/or Dislocation Procedures on the Humerus (Upper Arm) and Elbow.Musculoskeletal. Orthopedic Procedures\"","category":"Surgery","procedureDetails":"\"The provider treats a fracture of the humerus the upper arm bone through or above a condyle a rounded projection at the end of the bone but without extending between the condyles in a closed procedure. He manipulates the fracture into alignment without making an incision. He may apply tape to the skin or attach an external device to apply traction force to aid in restoring alignment.\"","version":"CPT 2026"},{"type":"CPT","code":"24538","description":"\"Fracture and/or Dislocation Procedures on the Humerus (Upper Arm) and Elbow.Musculoskeletal. Orthopedic Procedures\"","category":"Surgery","procedureDetails":"\"The provider treats a fracture of the humerus the upper arm bone through or above a condyle a rounded projection at the end of the bone but without extending between the condyles in a percutaneous procedure. He inserts pins or wires through the skin into the bone to hold the fracture in place.\"","version":"CPT 2026"},{"type":"CPT","code":"34530","description":"\"Venous Reconstruction Procedures.Cardiovascular Surgery. Vascular Surgery. Endovascular repair \"","category":"Surgery","procedureDetails":"\"In this procedure the provider makes an incision near the knee. She divides the saphenous vein and attaches it to the popliteal vein.\"","version":"CPT 2026"},{"type":"CPT","code":"43453","description":"\"Manipulation Procedures on the Esophagus.\"","category":"Surgery","procedureDetails":"\"The provider passes dilators over a guide wire to widen a narrowed area of the esophagus and improve swallowing.\"","version":"CPT 2026"},{"type":"CPT","code":"45300","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He may also collect a sample of tissue by brushing or washing.\"","version":"CPT 2026"},{"type":"CPT","code":"45303","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He also dilates a stricture or narrowing in the passage of the colon and rectum using a balloon or other device.\"","version":"CPT 2026"},{"type":"CPT","code":"45305","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He also takes one or more biopsies of tissue from the area.\"","version":"CPT 2026"},{"type":"CPT","code":"45307","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the physician performs a lower GI tract proctosigmoidoscopy.\"","version":"CPT 2026"},{"type":"CPT","code":"45308","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He then removes a single tumor polyp or other lesion using hot biopsy forceps or bipolar cautery.\"","version":"CPT 2026"},{"type":"CPT","code":"45309","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He then removes a tumor polyp or other lesion using a snare technique.\"","version":"CPT 2026"},{"type":"CPT","code":"45315","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He then removes multiple tumors polyps or other lesion using a combination of techniques such as hot biopsy forceps bipolar cautery or a snare.\"","version":"CPT 2026"},{"type":"CPT","code":"45317","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a short rigid instrument with a camera at its one end. He then controls the bleeding in the area using various methods like injection bipolar cautery unipolar cautery laser heater probe stapler or plasma coagulator.\"","version":"CPT 2026"},{"type":"CPT","code":"45320","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoid scope a shorter rigid instrument with a camera at its one end. He then ablates the tumor polyp or other lesion which are difficult to treat even using techniques like hot biopsy forceps bipolar cautery or a snare.\"","version":"CPT 2026"},{"type":"CPT","code":"45321","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoidoscope a short rigid instrument with a camera at its one end. He then decompresses the volvulus an abnormal twisting of the loop of the intestine which causes a bowel obstruction.\"","version":"CPT 2026"},{"type":"CPT","code":"45327","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a proctosigmoidoscope a short rigid instrument with a camera at its one end. He then uses the channel in the scope to introduce a stent and then places the stent at the site of stricture or abnormal narrowing.\"","version":"CPT 2026"},{"type":"CPT","code":"45330","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and sigmoid colon with a flexible sigmoidoscope a tubular instrument with a light source and camera to determine the cause for a patients symptoms such as diarrhea constipation or abdominal pain. He takes samples of any suspicious tissue by brushing or washing the area to collect cells for laboratory analysis.\"","version":"CPT 2026"},{"type":"CPT","code":"45331","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the rectum and the sigmoid colon using a sigmoidoscope a flexible narrow tube with a camera at its one end. He then takes one or more biopsies from the colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45332","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and colon using a flexible colonoscope a tubular instrument with a light source and camera. He then identifies and removes foreign bodies that might obstruct or damage the intestine.\"","version":"CPT 2026"},{"type":"CPT","code":"45333","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and sigmoid colon using a flexible colonoscope a tubular instrument with a light source and camera. He then identifies and removes one or more tumors polyps or other lesions using hot biopsy forceps.\"","version":"CPT 2026"},{"type":"CPT","code":"45334","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and sigmoid colon using a flexible colonoscope a tubular instrument with a light source and camera to identify the source of internal bleeding. He controls the bleeding in the sigmoid colon by any method.\"","version":"CPT 2026"},{"type":"CPT","code":"45335","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider inserts a flexible endoscope into the anus and navigates the scope to the rectum and lower (sigmoid) colon. The provider performs one or more injections into the submucosa (the tissue below the mucous membrane).\"","version":"CPT 2026"},{"type":"CPT","code":"45337","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and the sigmoid colon using a sigmoidoscope a flexible narrow tube with a camera at its inserted end. If he finds a volvulus or megacolon he introduces a stiff tube and decompresses it.\"","version":"CPT 2026"},{"type":"CPT","code":"45338","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a flexible sigmoidoscope a flexible narrow tube with a camera at its one end. He then removes a single tumor polyp or other lesion using a snare technique.\"","version":"CPT 2026"},{"type":"CPT","code":"45340","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the anus rectum and the sigmoid colon using a sigmoidoscope a flexible narrow tube with a camera at its inserted end. He uses a channel in the scope to introduce a balloon catheter and inflates the balloon to dilate a stricture or abnormal narrowing of the colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45341","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a sigmoidoscope a flexible narrow tube with a camera at its one end.  He then uses the channel in the scope to introduce an ultrasound probe and performs an ultrasound examination of the colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45342","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the inner part of the anus rectum and the sigmoid colon using a sigmoidscope a flexible narrow tube with a camera at its one end.  He then uses the channel in the scope to perform an ultrasound guided fine needle aspiration and or biopsy of abnormal tissue.\"","version":"CPT 2026"},{"type":"CPT","code":"45346","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider uses a flexible sigmoidoscope to examine the sigmoid colon. She also ablates the polyp tumor or any other lesion present. The procedure may include predilation and postdilation along with passage for a guide wire.\"","version":"CPT 2026"},{"type":"CPT","code":"45347","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider examines the rectum and sigmoid colon via a sigmoidoscope. He also performs endoscopic introduction of a stent.\"","version":"CPT 2026"},{"type":"CPT","code":"45349","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider performs mucosal resection using a flexible sigmoidoscope a scope designed to examine the rectum and sigmoid colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45350","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider ligates a structure such as a hemorrhoid with a flexible band using a flexible sigmoidoscope a scope designed to examine the rectum and sigmoid colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45378","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the colon and rectum using a colonoscope a flexible tube with a camera at its inserted end. If he sees any areas of abnormal mucosa or tissue he takes samples using a brush passed through the scope or irrigates the area with warm saline and aspirates the washings through the scope. He sends the specimens to the laboratory for diagnostic analysis.\"","version":"CPT 2026"},{"type":"CPT","code":"45379","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the colon and rectum using a colonoscope a tubular instrument with a light source and camera which he inserts through the rectum to look for a blockage. He identifies and removes foreign bodies such as swallowed objectives that could damage or obstruct the colon.\"","version":"CPT 2026"},{"type":"CPT","code":"45380","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and colon using a flexible colonoscope a tubular instrument with a light source and camera to look for the cause of a patients symptoms which may include diarrhea constipation rectal bleeding or abdominal pain. He excises one or more suspicious areas of tissue using biopsy forceps and submits the specimens for laboratory analysis.\"","version":"CPT 2026"},{"type":"CPT","code":"45381","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider inserts a flexible endoscope into the anus and navigates the scope through the entire colon. The provider performs one or more injections into the submucosa (the tissue below the mucous membrane).\"","version":"CPT 2026"},{"type":"CPT","code":"45382","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the colon and rectum using a colonoscope a tubular instrument with a light source and camera to identify the source of internal bleeding. He then controls the bleeding in the colon by various methods.\"","version":"CPT 2026"},{"type":"CPT","code":"45384","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the rectum and colon using a flexible colonoscope a tubular instrument with a light source and camera. He removes one or more tumors polyps or other lesions using hot biopsy forceps.\"","version":"CPT 2026"},{"type":"CPT","code":"45385","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the colon and rectum using a colonoscope a long thin flexible tubular instrument with a light source and camera. He removes one or more tumors polyps or other lesions with a snare a wire loop that he passes around the base of the lesion and tightens it until the wire cuts through the lesion.\"","version":"CPT 2026"},{"type":"CPT","code":"45386","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the inner part of the colon and rectum using a colonoscope a long thin flexible tubular instrument with a light source and camera. He then uses a channel in the scope to introduce a balloon catheter and inflates the balloon to dilate one or more sites of stricture an area of abnormal narrowing.\"","version":"CPT 2026"},{"type":"CPT","code":"45388","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider performs flexible colonoscopy to destroy one or more tumors polyps or other lesions. The procedure includes but does not require guide wire passage and dilating the site before and after the procedure.\"","version":"CPT 2026"},{"type":"CPT","code":"45389","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"In this procedure the provider performs flexible colonoscopy along with placing a stent using an endoscope. The procedure also includes but does not require guide wire passage and dilating the site before and after the procedure.\"","version":"CPT 2026"},{"type":"CPT","code":"45390","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider performs flexible colonoscopy along with excision of mucous membrane tissue using an endoscope.\"","version":"CPT 2026"},{"type":"CPT","code":"45391","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider examines the part of the colon that includes the rectum sigmoid descending transverse or ascending colon and cecum using a colonoscope a long thin flexible tubular instrument with a light source and camera. He uses a channel in the scope to introduce an ultrasound probe and performs an ultrasound examination of the colon. This endoscopic ultrasound examination helps the provider diagnose and stage colon cancer.\"","version":"CPT 2026"},{"type":"CPT","code":"45392","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider uses a colonoscope a flexible tubular instrument with a light source and camera to examine the colon rectum sigmoid descending transverse or ascending colon the cecum and adjacent structures. He then uses a channel in the scope to perform an ultrasound–guided fine needle aspiration or biopsy of abnormal tissue.\"","version":"CPT 2026"},{"type":"CPT","code":"45393","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider performs flexible colonoscopy and decompresses a dilated colon; he may leave a tube in place for continued decompression.\"","version":"CPT 2026"},{"type":"CPT","code":"45395","description":"\"Excisional Laparoscopic Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"The provider removes the entire rectum with the help of a laparoscope. After the resection of the rectum he attaches the remaining end of the large intestine to the wall of the abdomen and creates an opening outside of the body.\"","version":"CPT 2026"},{"type":"CPT","code":"45397","description":"\"Excisional Laparoscopic Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"Using laparoscopic techniques the provider removes the entire rectum pulls up the anus and attaches it to the end of the colon and creates a pouch of colon for collection of feces. In addition he may incise the small intestine attach it to the wall of the abdomen and create an opening outside of the body to divert feces until the anastomosis has had time to heal.\"","version":"CPT 2026"},{"type":"CPT","code":"45398","description":"\"Endoscopy Procedures on the Rectum.\"","category":"Surgery","procedureDetails":"\"During a flexible colonoscopy the provider ligates a structure such as a hemorrhoid using a flexible band.\"","version":"CPT 2026"},{"type":"CPT","code":"45399","description":"\"Other Procedures on the Colon and Rectum.\"","category":"Surgery","procedureDetails":"\"Use this code to report a procedure on the colon for which there is no specific code available.\"","version":"CPT 2026"},{"type":"HCPCS","code":"A4453","description":"Various Medical Supplies Including Tapes and Surgical Dressings .","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"A6453","description":"Bandages .","category":"Transportation Services. medical equipment and supplies","version":"HCPS"},{"type":"HCPCS","code":"G0453","description":"Miscellaneous Services .Administrative. social. and other medical services","category":"Medical Equipment and Supplies","version":"HCPS"},{"type":"HCPCS","code":"J1453","description":"Drugs Administered by Injection .Injectable drugs and biologicals","category":"Injectable Drugs and infusion services","version":"HCPS"},{"type":"HCPCS","code":"S9453","description":"Miscellaneous Supplies and Services .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4530","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4531","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4532","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4533","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4534","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4535","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4536","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4537","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4538","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"},{"type":"HCPCS","code":"T4539","description":"Incontinence Supplies .","category":"Mental Health and Substance Abuse","version":"HCPS"}]
